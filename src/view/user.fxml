<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.UserController"
            stylesheets="@style.css">

    <!-- HEADER -->
    <top>

        <VBox alignment="CENTER"
              spacing="15"
              styleClass="top-panel">

            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="FORM DATA USER"
                   styleClass="title"/>

        </VBox>

    </top>

    <!-- CONTENT -->

    <center>

        <VBox spacing="20">

            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <!-- FORM -->

            <GridPane hgap="20"
                      vgap="18">

                <columnConstraints>

                    <ColumnConstraints minWidth="150"/>
                    <ColumnConstraints minWidth="250"/>

                    <ColumnConstraints minWidth="150"/>
                    <ColumnConstraints minWidth="250"/>

                </columnConstraints>

                <!-- ID -->

                <Label text="ID"/>

                <TextField fx:id="txtId"
                           editable="false"
                           GridPane.columnIndex="1"/>

                <!-- USERNAME -->

                <Label text="Username"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtUsername"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <!-- PASSWORD -->

                <Label text="Password"
                       GridPane.rowIndex="2"/>

                <PasswordField fx:id="txtPassword"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="2"/>

                <!-- ROLE -->

                <Label text="Role"
                       GridPane.rowIndex="3"/>

                <ComboBox fx:id="cbRole"
                          prefWidth="250"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="3"/>

            </GridPane>

            <!-- BUTTON -->

            <HBox alignment="CENTER"
                  spacing="15">

                <Button text="💾 Simpan"
                        fx:id="btnSimpan"
                        onAction="#handleSimpan"
                        styleClass="btn-save"/>

                <Button text="✏ Edit"
                        fx:id="btnEdit"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>

                <Button text="🗑 Hapus"
                        fx:id="btnHapus"
                        onAction="#handleHapus"
                        styleClass="btn-danger"/>

                <Button text="✖ Batal"
                        onAction="#handleBatal"
                        styleClass="btn-cancel"/>

            </HBox>

            <!-- SEARCH -->

            <HBox spacing="10">

                <Label text="Cari"/>

                <TextField fx:id="txtCari"
                           HBox.hgrow="ALWAYS"/>

                <Button text="Cari"
                        onAction="#handleCari"/>

            </HBox>

            <!-- TABLE -->

            <TableView fx:id="tableUser"
                       prefHeight="350">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"/>

                    <TableColumn fx:id="colUsername"
                                 text="Username"/>

                    <TableColumn fx:id="colRole"
                                 text="Role"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>